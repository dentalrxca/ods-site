---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="ODS Summit">

  <!-- HERO -->
  <section class="hero container">
    <div class="hero-card">
      <h1>ODS Leadership & Operations Summit</h1>
      <p>
        A one‑day intensive designed to help dental leaders strengthen operations,
        elevate team performance, and build long‑term practice stability.
      </p>
    </div>
  </section>

  <!-- WHAT THE SUMMIT IS -->
  <section class="about-section container">
    <h2 class="section-title">What Is the ODS Summit?</h2>
    <p>
      The ODS Summit is a focused, high‑impact training event for dental practice
      owners, managers, and clinical leaders. We cover the systems, leadership
      frameworks, and operational strategies that modern practices need to thrive.
    </p>
    <p>
      This is not a lecture. It’s hands‑on, practical, and built around real
      challenges dental teams face every day.
    </p>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="value-grid container">
    <div class="value-card">
      <h3>Practice Owners</h3>
      <p>Build clarity, reduce stress, and strengthen your leadership foundation.</p>
    </div>

    <div class="value-card">
      <h3>Office Managers</h3>
      <p>Learn systems that create consistency, confidence, and team alignment.</p>
    </div>

    <div class="value-card">
      <h3>Clinical Leaders</h3>
      <p>Improve communication, workflow efficiency, and patient experience.</p>
    </div>
  </section>

  <!-- WHAT YOU'LL LEARN -->
  <section class="about-section container">
    <h2 class="section-title">What You’ll Learn</h2>

    <ul class="service-checklist">
      <li>✔ Leadership frameworks for modern dental teams</li>
      <li>✔ Scheduling systems that reduce chaos</li>
      <li>✔ Communication structures that prevent breakdowns</li>
      <li>✔ Workflow optimization for clinical + admin teams</li>
      <li>✔ KPI tracking and operational clarity</li>
      <li>✔ How to build a scalable practice foundation</li>
    </ul>
  </section>

  <!-- AGENDA OVERVIEW -->
  <section class="about-section container">
    <h2 class="section-title">Summit Agenda Overview</h2>

    <div class="leader-card">
      <div class="leader-info">
        <h3>Morning Session</h3>
        <p>
          Leadership foundations, communication systems, and team alignment strategies.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>Mid‑Day Workshop</h3>
        <p>
          Hands‑on operational system building — scheduling, workflows, and daily structure.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>Afternoon Session</h3>
        <p>
          KPI tracking, growth planning, and long‑term stability frameworks.
        </p>
      </div>
    </div>
  </section>

  <!-- SPEAKER -->
  <section class="about-section container">
    <h2 class="section-title">Featured Speaker</h2>

    <div class="leader-card">
      <img src="/assets/seerat-sandhu.jpeg" alt="Dr. Seerat Sandhu" />
      <div class="leader-info">
        <h3>Dr. Seerat Sandhu, DDS</h3>
        <p>
          Clinical Director at Optimal Dental Solutions. Dr. Sandhu brings years of
          clinical expertise, leadership experience, and a passion for helping dental
          teams operate at their highest potential.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta container">
    <h2>Register for the ODS Summit</h2>
    <p>
      Join us for a high‑impact day of leadership development, operational clarity,
      and practical systems that transform your practice.
    </p>

    <div class="cta-buttons">
      <a href="/contact" class="btn-primary">Reserve Your Spot</a>
      <a href="/contact" class="btn-secondary">Request More Info</a>
    </div>
  </section>

</MainLayout>
