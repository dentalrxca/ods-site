---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="ODS Staffing">

  <!-- HERO -->
  <section class="hero container">
    <div class="hero-card">
      <h1>ODS Dental Staffing & Placement</h1>
      <p>
        Connecting dental practices with qualified, reliable, and professional
        candidates — and helping dental professionals find the right long‑term fit.
      </p>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="about-section container">
    <h2 class="section-title">What We Do</h2>
    <p>
      ODS Staffing provides structured, reliable hiring support for dental practices
      across California. We help offices find qualified candidates while ensuring
      professionals are matched with roles that fit their skills, goals, and work style.
    </p>
    <p>
      Our staffing system is built around clarity, communication, and long‑term
      placement success.
    </p>
  </section>

  <!-- FOR PRACTICES -->
  <section class="value-grid container">
    <div class="value-card">
      <h3>For Dental Practices</h3>
      <p>
        We help you hire confidently with pre‑screened candidates, clear communication,
        and structured placement support.
      </p>
    </div>

    <div class="value-card">
      <h3>For Dental Professionals</h3>
      <p>
        We connect you with offices that match your skills, personality, and long‑term
        career goals — not just “any job.”
      </p>
    </div>

    <div class="value-card">
      <h3>Long‑Term Placement</h3>
      <p>
        Our focus is stability. We help practices and candidates find the right fit
        for long‑term success.
      </p>
    </div>
  </section>

  <!-- STAFFING PROCESS -->
  <section class="about-section container">
    <h2 class="section-title">Our Staffing Process</h2>

    <div class="leader-card">
      <div class="leader-info">
        <h3>1. Intake & Requirements</h3>
        <p>
          Practices submit their staffing needs — role, schedule, experience level,
          and office culture.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>2. Candidate Screening</h3>
        <p>
          We review resumes, verify experience, and ensure candidates meet your
          operational and cultural requirements.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>3. Matching & Placement</h3>
        <p>
          We connect practices with qualified candidates and support both sides
          through interviews and onboarding.
        </p>
      </div>
    </div>
  </section>

  <!-- JOB CATEGORIES -->
  <section class="about-section container">
    <h2 class="section-title">Roles We Staff</h2>

    <ul class="service-checklist">
      <li>✔ Front Office / Reception</li>
      <li>✔ Treatment Coordinators</li>
      <li>✔ Office Managers</li>
      <li>✔ Dental Assistants (DA / RDA)</li>
      <li>✔ Registered Dental Hygienists (RDH)</li>
      <li>✔ Associate Dentists</li>
      <li>✔ Specialty Assistants</li>
    </ul>
  </section>

  <!-- CTA -->
  <section class="cta container">
    <h2>Need Staffing Support?</h2>
    <p>
      Whether you're hiring for a single role or building a long‑term staffing
      pipeline, ODS provides structured, reliable support.
    </p>

    <div class="cta-buttons">
      <a href="/contact" class="btn-primary">Request Staffing Help</a>
      <a href="/contact" class="btn-secondary">Submit a Candidate Application</a>
    </div>
  </section>

</MainLayout>
