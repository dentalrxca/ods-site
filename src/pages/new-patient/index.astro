---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="New Patient Information">
  <section class="hero">
    <div class="hero-content">
      <h1>New Patient Information</h1>
      <p>Everything you need for your first visit to Optimal Dental Solutions.</p>
    </div>
  </section>

  <section class="about-preview">
    <h2>What to Expect</h2>
    <p>
      Your first visit includes a thorough exam, digital imaging as needed, and time to discuss your goals and concerns.
    </p>

    <h2>New Patient Forms</h2>
    <p>
      Save time by completing your forms before you arrive. (This can link to downloadable or online forms later.)
    </p>

    <h2>Preparing for Your Visit</h2>
    <p>
      Please bring your ID, insurance information, and any previous dental records you’d like us to review.
    </p>
  </section>
</MainLayout>
