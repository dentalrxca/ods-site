<MainLayout title="Smile Gallery">
  <section class="hero">
    <div class="hero-content">
      <h1>Smile Gallery</h1>
      <p>Examples of the transformations and results our patients have achieved.</p>
    </div>
  </section>

  <section class="about-preview">
