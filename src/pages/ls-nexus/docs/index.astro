---
import MainLayout from "../../../layouts/MainLayout.astro";
---

<MainLayout title="LS Nexus Documentation">

  <!-- HERO -->
  <section class="hero container">
    <div class="hero-card">
      <h1>LS Nexus Documentation</h1>
      <p>
        Learn how to use the LS Nexus AI Staffing Platform. Explore guides for
        candidates, practices, platform features, and future API integrations.
      </p>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="about-section container">
    <h2 class="section-title">Platform Overview</h2>
    <p>
      LS Nexus is an AI‑powered staffing platform designed for dental practices and
      dental professionals. It uses structured profiles, behavioral insights, and
      alignment scoring to generate high‑quality matches.
    </p>
    <p>
      This documentation provides everything you need to understand and use the
      platform effectively.
    </p>
  </section>

  <!-- DOC SECTIONS -->
  <section class="value-grid container">

    <div class="value-card">
      <h3>Getting Started</h3>
      <p>
        Learn the basics of LS Nexus, how to create an account, and how to navigate
        the platform.
      </p>
      <a href="/ls-nexus/docs/getting-started" class="btn-secondary">View Guide</a>
    </div>

    <div class="value-card">
      <h3>Candidate Guide</h3>
      <p>
        Understand how to create your profile, track matches, and manage your
        dashboard.
      </p>
      <a href="/ls-nexus/docs/candidate" class="btn-secondary">View Guide</a>
    </div>

    <div class="value-card">
      <h3>Practice Guide</h3>
      <p>
        Learn how to submit staffing needs, review candidates, and manage your
        practice dashboard.
      </p>
      <a href="/ls-nexus/docs/practice" class="btn-secondary">View Guide</a>
    </div>

    <div class="value-card">
      <h3>Matching Engine</h3>
      <p>
        Explore how LS Nexus calculates match scores, alignment indicators, and
        recommendations.
      </p>
      <a href="/ls-nexus/docs/matching" class="btn-secondary">View Guide</a>
    </div>

    <div class="value-card">
      <h3>API (Coming Soon)</h3>
      <p>
        Developer documentation for integrating LS Nexus with external systems.
      </p>
      <a href="/ls-nexus/docs/api" class="btn-secondary">Preview</a>
    </div>

    <div class="value-card">
      <h3>Support</h3>
      <p>
        Troubleshooting, FAQs, and help resources for all users.
      </p>
      <a href="/ls-nexus/docs/support" class="btn-secondary">View Support</a>
    </div>

  </section>

  <!-- CTA -->
  <section class="cta container">
    <h2>Need Help?</h2>
    <p>
      If you need assistance with LS Nexus, explore the documentation or contact
      our support team.
    </p>

    <div class="cta-buttons">
      <a href="/ls-nexus/docs/support" class="btn-primary">Go to Support</a>
      <a href="/ls-nexus" class="btn-secondary">Back to Platform Home</a>
    </div>
  </section>

</MainLayout>
