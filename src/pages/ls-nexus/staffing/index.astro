---
import MainLayout from "../../../layouts/MainLayout.astro";
---

<MainLayout title="LS Nexus Staffing">

  <!-- HERO -->
  <section class="hero container">
    <div class="hero-card">
      <h1>LS Nexus AI Staffing Platform</h1>
      <p>
        A smarter, structured, AI‑powered staffing system built specifically for
        dental practices and dental professionals. Designed for long‑term alignment,
        not short‑term placement.
      </p>
    </div>
  </section>

  <!-- WHAT LS NEXUS DOES -->
  <section class="about-section container">
    <h2 class="section-title">Smarter Staffing for Modern Dental Practices</h2>
    <p>
      LS Nexus uses structured profiles, behavioral insights, and AI‑powered matching
      to connect practices with candidates who fit their operational needs, culture,
      and long‑term goals.
    </p>
    <p>
      No more guessing. No more mismatches. No more turnover.
    </p>
  </section>

  <!-- VALUE GRID -->
  <section class="value-grid container">
    <div class="value-card">
      <h3>AI‑Powered Matching</h3>
      <p>
        LS Nexus analyzes skills, experience, communication style, and culture fit
        to identify high‑alignment matches.
      </p>
    </div>

    <div class="value-card">
      <h3>Structured Profiles</h3>
      <p>
        Practices and candidates complete detailed profiles that improve accuracy
        and reduce hiring friction.
      </p>
    </div>

    <div class="value-card">
      <h3>Long‑Term Stability</h3>
      <p>
        Our system focuses on alignment, not availability — reducing turnover and
        improving team consistency.
      </p>
    </div>
  </section>

  <!-- FOR PRACTICES -->
  <section class="about-section container">
    <h2 class="section-title">For Dental Practices</h2>
    <p>
      Submit your staffing requirements and LS Nexus will begin matching you with
      qualified candidates aligned to your role, schedule, culture, and workflow.
    </p>

    <div class="cta-buttons">
      <a href="/ls-nexus/practice" class="btn-primary">Submit Practice Profile</a>
    </div>
  </section>

  <!-- FOR CANDIDATES -->
  <section class="about-section container">
    <h2 class="section-title">For Dental Professionals</h2>
    <p>
      Create your LS Nexus candidate profile to be matched with offices that fit
      your skills, personality, and long‑term career goals.
    </p>

    <div class="cta-buttons">
      <a href="/ls-nexus/candidate" class="btn-primary">Create Candidate Profile</a>
    </div>
  </section>

  <!-- PLATFORM FEATURES -->
  <section class="about-section container">
    <h2 class="section-title">Platform Features</h2>

    <ul class="service-checklist">
      <li>✔ AI‑assisted candidate ranking</li>
      <li>✔ Culture & communication style profiling</li>
      <li>✔ Dental‑specific role mapping</li>
      <li>✔ Practice & candidate dashboards</li>
      <li>✔ Long‑term placement tracking</li>
      <li>✔ Integrated ODS Staffing support</li>
    </ul>
  </section>

  <!-- CTA -->
  <section class="cta container">
    <h2>Start Using LS Nexus Today</h2>
    <p>
      Whether you're hiring or looking for your next role, LS Nexus provides a
      smarter, more structured way to connect.
    </p>

    <div class="cta-buttons">
      <a href="/ls-nexus/practice" class="btn-primary">For Practices</a>
      <a href="/ls-nexus/candidate" class="btn-secondary">For Candidates</a>
    </div>
  </section>

</MainLayout>
