---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="LS Nexus AI Staffing Platform">

  <!-- HERO -->
  <section class="hero container">
    <div class="hero-card">
      <h1>LS Nexus — AI‑Driven Dental Staffing</h1>
      <p>
        LS Nexus is our intelligent staffing platform that connects dental practices
        with the right candidates using structured data, behavioral insights, and
        AI‑powered matching.
      </p>
    </div>
  </section>

  <!-- WHAT LS NEXUS IS -->
  <section class="about-section container">
    <h2 class="section-title">What Is LS Nexus?</h2>
    <p>
      LS Nexus is built specifically for dental staffing. It combines operational
      requirements, role expectations, personality fit, and experience data to
      match practices with candidates who are aligned for long‑term success.
    </p>
    <p>
      Instead of “post and hope,” LS Nexus turns staffing into a structured,
      predictable system.
    </p>
  </section>

  <!-- FOR PRACTICES / FOR CANDIDATES -->
  <section class="value-grid container">
    <div class="value-card">
      <h3>For Dental Practices</h3>
      <p>
        Define your ideal candidate profile—experience, schedule, culture, and
        operational expectations—and LS Nexus surfaces the best‑fit matches.
      </p>
    </div>

    <div class="value-card">
      <h3>For Dental Professionals</h3>
      <p>
        Create a profile that reflects your skills, preferences, and career goals.
        LS Nexus connects you with practices where you can actually thrive.
      </p>
    </div>

    <div class="value-card">
      <h3>For Long‑Term Stability</h3>
      <p>
        The platform is designed to reduce turnover by focusing on alignment,
        not just availability.
      </p>
    </div>
  </section>

  <!-- HOW THE PLATFORM WORKS -->
  <section class="about-section container">
    <h2 class="section-title">How the Platform Works</h2>

    <div class="leader-card">
      <div class="leader-info">
        <h3>1. Structured Profiles</h3>
        <p>
          Practices and candidates complete structured profiles that capture
          operational needs, experience, communication style, and work preferences.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>2. AI‑Powered Matching</h3>
        <p>
          LS Nexus analyzes profile data to identify high‑alignment matches based
          on role requirements, culture fit, and long‑term potential.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>3. Guided Placement</h3>
        <p>
          ODS Staffing oversees the process—introductions, interviews, and
          onboarding—ensuring both sides are supported throughout placement.
        </p>
      </div>
    </div>
  </section>

  <!-- PLATFORM FEATURES -->
  <section class="about-section container">
    <h2 class="section-title">Platform Features</h2>

    <ul class="service-checklist">
      <li>✔ Dental‑specific role and skills mapping</li>
      <li>✔ Culture and communication style profiling</li>
      <li>✔ AI‑assisted candidate ranking and matching</li>
      <li>✔ Practice and candidate dashboards</li>
      <li>✔ Long‑term placement tracking and insights</li>
      <li>✔ Integrated with ODS Staffing support</li>
    </ul>
  </section>

  <!-- CTA -->
  <section class="cta container">
    <h2>Bring LS Nexus Into Your Staffing Strategy</h2>
    <p>
      Whether you're building a long‑term hiring pipeline or looking for your next
      role, LS Nexus provides a smarter, more structured way to connect.
    </p>

    <div class="cta-buttons">
      <a href="/contact" class="btn-primary">Request Platform Access</a>
      <a href="/staffing" class="btn-secondary">Learn More About ODS Staffing</a>
    </div>
  </section>

</MainLayout>
