---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Dental Services">
  <section class="hero">
    <div class="hero-content">
      <h1>Comprehensive Dental Services</h1>
      <p>From routine care to advanced restorative and cosmetic treatments.</p>
    </div>
  </section>

  <section class="features">
    <div class="feature">
      <h3>Preventive Care</h3>
      <p>Cleanings, exams, fluoride, and sealants to protect your smile.</p>
    </div>
    <div class="feature">
      <h3>Restorative Dentistry</h3>
      <p>Fillings, crowns, bridges, and implants to rebuild function.</p>
    </div>
    <div class="feature">
      <h3>Cosmetic Dentistry</h3>
      <p>Whitening, veneers, and smile makeovers tailored to your goals.</p>
    </div>
  </section>

  <section class="about-preview">
    <h2>Specialized Treatments</h2>
    <p>
      We offer treatment plans designed around your needs, whether you’re addressing pain, aesthetics, or long‑term oral health.
    </p>
  </section>
</MainLayout>
