---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Services">

  <!-- HERO -->
  <section class="hero container">
    <div class="hero-card">
      <h1>Services Designed for Modern Dental Practices</h1>
      <p>
        ODS provides structured, practical solutions that help dental teams operate
        with clarity, confidence, and long‑term stability.
      </p>
    </div>
  </section>

  <!-- SERVICE CATEGORIES -->
  <section class="value-grid container">
    <div class="value-card">
      <h3>Operational Systems</h3>
      <p>
        Scheduling optimization, workflow design, front‑office systems, and daily
        operational structure that reduces stress and increases efficiency.
      </p>
    </div>

    <div class="value-card">
      <h3>Leadership Development</h3>
      <p>
        Coaching and training for clinical and administrative leaders to build
        confidence, communication, and team alignment.
      </p>
    </div>

    <div class="value-card">
      <h3>Growth & Expansion Strategy</h3>
      <p>
        Long‑term planning, multi‑location strategy, KPI tracking, and scalable
        systems that support sustainable growth.
      </p>
    </div>
  </section>

  <!-- WHY PRACTICES CHOOSE ODS -->
  <section class="about-section container">
    <h2 class="section-title">Why Practices Choose ODS</h2>

    <div class="leader-card">
      <div class="leader-info">
        <h3>Clear, Actionable Systems</h3>
        <p>
          We don’t deliver vague advice — we build real systems your team can follow
          every day with confidence.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>Team‑Centered Approach</h3>
        <p>
          Your team becomes aligned, confident, and supported — creating a better
          patient experience and a healthier practice culture.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>Long‑Term Stability</h3>
        <p>
          We build systems that last — not quick fixes. Your practice becomes more
          predictable, scalable, and stress‑free.
        </p>
      </div>
    </div>
  </section>

  <!-- HOW OUR PROCESS WORKS -->
  <section class="about-section container">
    <h2 class="section-title">How Our Process Works</h2>

    <div class="leader-card">
      <div class="leader-info">
        <h3>1. Practice Audit</h3>
        <p>
          We review your workflows, scheduling, communication systems, leadership
          structure, and patient experience to identify gaps.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>2. System Design</h3>
        <p>
          We build customized operational systems tailored to your practice’s size,
          goals, and team structure.
        </p>
      </div>
    </div>

    <div class="leader-card">
      <div class="leader-info">
        <h3>3. Implementation & Training</h3>
        <p>
          We train your team, install new workflows, and ensure adoption — so your
          practice runs smoothly from day one.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="about-section container">
    <h2 class="section-title">What’s Included</h2>

    <ul class="service-checklist">
      <li>✔ Full practice operations audit</li>
      <li>✔ Workflow & scheduling optimization</li>
      <li>✔ Leadership coaching & development</li>
      <li>✔ Team communication systems</li>
      <li>✔ KPI tracking & reporting structure</li>
      <li>✔ Growth & expansion planning</li>
      <li>✔ On‑site or virtual training</li>
    </ul>
  </section>

  <!-- CTA -->
  <section class="cta container">
    <h2>Ready to Strengthen Your Practice?</h2>
    <p>
      Whether you're refining operations, improving team communication, or preparing
      for growth, ODS provides the structure and support you need.
    </p>

    <div class="cta-buttons">
      <a href="/contact" class="btn-primary">Get Started</a>
      <a href="/contact" class="btn-secondary">Book a Consultation</a>
    </div>
  </section>

</MainLayout>
