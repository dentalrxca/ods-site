---
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global-v2.css" />
  </head>

  <body>

    <!-- ⭐ CLEAN ODS HEADER — NO VIDEO ⭐ -->
    <header class="ods-header">
      <div class="ods-header-inner">
        <div class="ods-logo">Optimal Dental Solutions</div>

        <nav class="ods-nav">
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/services">Services</a>
          <a href="/summit">Summit</a>
          <a href="/staffing">Staffing</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

  </body>
</html>
